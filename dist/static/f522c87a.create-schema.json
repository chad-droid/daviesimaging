        "type": "text"
      },
      {
        "options": {
          "hotspot": true
        },
        "name": "coverImage",
        "type": "image"
      },
      {
        "name": "author",
        "type": "string"
      },
      {
        "options": {
          "list": [
            {
              "title": "Strategy",
              "value": "strategy"
            },
            {
              "title": "Case Study",
              "value": "case-study"
            },
            {
              "title": "Trends",
              "value": "trends"
            },
            {
              "title": "Product Updates",
              "value": "product-updates"
            },
            {
              "title": "Behind the Scenes",
              "value": "behind-the-scenes"
            }
          ]
        },
        "name": "category",
        "type": "string"
      },
      {
        "validation": [
          {
            "level": "error",
            "rules": [
              {
                "flag": "presence",
                "constraint": "required"
