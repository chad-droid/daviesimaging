                            {
                              "flag": "uri",
                              "constraint": {
                                "options": {
                                  "scheme": [
                                    "/^http$/",
                                    "/^https$/",
                                    "/^mailto$/"
                                  ],
                                  "allowRelative": true,
                                  "relativeOnly": false,
                                  "allowCredentials": false
                                }
                              }
                            }
                          ]
                        }
                      ],
                      "name": "href",
